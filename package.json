{
  "name": "@aliakakis/react-templates-components",
  "version": "1.0.0",
  "description": "Simple template based React Components",
  "type": "module",
  "scripts": {
    "build": "npm run preBuildChecks && cross-env NODE_ENV=production tsdown",
    "build:react-compiler": "npm run preBuildChecks && cross-env NODE_ENV=production USE_REACT_COMPILER=true tsdown",
    "dev": "tsdown",
    "dev:react-compiler": "cross-env USE_REACT_COMPILER=true tsdown",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "preBuildChecks": "npm run typecheck && npm run lint && npm run format && npm run test",
    "prepare": "husky",
    "postinstall": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@rollup/plugin-babel": "7.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "stylelint": "17.11.0",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5",
    "vitest-browser-react": "2.2.0"
  },
  "keywords": [
    "react",
    "templates"
  ],
  "author": "Antonios Liakakis",
  "license": "ISC",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0"
  }
}
