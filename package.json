{
  "name": "@aliakakis/react-templates-components",
  "version": "1.0.0",
  "description": "Simple template based React Components",
  "type": "module",
  "scripts": {
    "build": "npm run preBuildChecks && cross-env NODE_ENV=production tsdown",
    "build:react-compiler": "npm run preBuildChecks && cross-env NODE_ENV=production USE_REACT_COMPILER=true tsdown",
    "dev": "tsdown",
    "dev:react-compiler": "cross-env USE_REACT_COMPILER=true tsdown",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "husky install && npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  },
  "keywords": [
    "react",
    "templates"
  ],
  "author": "Antonios Liakakis",
  "license": "ISC",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  }
}
